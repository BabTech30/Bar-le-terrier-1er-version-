# LE TERRIER — Configuration Apache O2Switch
# ============================================================

# Activer le moteur de reecriture
RewriteEngine On
RewriteBase /

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- HSTS (Securite HTTPS stricte) ---
<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# --- URLS PROPRES (suppression .html) ---
# Redirection 301 : /page.html → /page
RewriteCond %{THE_REQUEST} \s/([^.]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Resolution interne : /page → /page.html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# --- PAGE D'ACCUEIL ---
DirectoryIndex index.html index.php

# --- PROTECTION DES DONNEES ---
# Bloquer l'acces direct au dossier data/ et backups
RewriteRule ^data/ - [F,L]
RewriteRule ^staging/data/ - [F,L]

# --- PROTECTION UPLOADS (autoriser images uniquement) ---
RewriteCond %{REQUEST_URI} ^/uploads/
RewriteCond %{REQUEST_URI} !\.(jpg|jpeg|png|webp|gif|svg)$ [NC]
RewriteRule . - [F,L]

# --- SECURITE HEADERS ---
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# --- SECURITE FICHIERS ---
<FilesMatch "\.(md|txt|json)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# Autoriser robots.txt, sitemap.xml et llms.txt
<Files "robots.txt">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</Files>
<Files "sitemap.xml">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</Files>
<Files "llms.txt">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</Files>
<Files "llms-full.txt">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</Files>

# Bloquer l'acces aux fichiers systeme
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# --- PREVENTION LISTING DOSSIERS ---
Options -Indexes

# --- CACHE & PERFORMANCE ---
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# --- COMPRESSION ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# --- UTF-8 ---
AddDefaultCharset UTF-8
