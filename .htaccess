# LE TERRIER — Configuration Apache O2Switch
# ============================================================

# Activer le moteur de reecriture
RewriteEngine On
RewriteBase /

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- PAGE D'ACCUEIL ---
# Servir index.html comme page d'accueil (pas index.php)
DirectoryIndex index.html

# --- PROTECTION DES DONNEES ---
# Bloquer l'acces direct au dossier data/
RewriteRule ^data/ - [F,L]

# --- SECURITE ---
# Bloquer l'acces aux fichiers sensibles
<FilesMatch "\.(md|txt|json)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# Autoriser robots.txt et sitemap.xml
<Files "robots.txt">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</Files>
<Files "sitemap.xml">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</Files>

# --- CACHE & PERFORMANCE ---
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
</IfModule>

# --- COMPRESSION ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
